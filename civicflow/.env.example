# ── Core ────────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
DB_NAME=civicflow

# JWT — Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# AES-256 Encryption — Generate with: python -c "import secrets; print(secrets.token_hex(16))"
ENCRYPTION_MASTER_KEY=REPLACE_WITH_32_CHAR_HEX_KEY

# ── AI ───────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Storage ─────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
REDIS_URL=redis://localhost:6379

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Get token from @BotFather on Telegram: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=YourBotUsername
# Random secret to verify webhook calls — generate with: python -c "import secrets; print(secrets.token_hex(16))"
TELEGRAM_WEBHOOK_SECRET=random_secret_here

# ── Document OCR ─────────────────────────────────────────────────────────────
# Windows: Download from https://github.com/oschwartz10612/poppler-windows
# Set to empty string on Linux/Mac (poppler installed via apt/brew)
POPPLER_PATH=C:/poppler/bin

# Whether to attempt auto-solving text CAPTCHAs using Gemini Vision
GEMINI_CAPTCHA_SOLVE=true

# ── Mock Portal (development only) ───────────────────────────────────────────
MOCK_PORTAL_PORT=5001
